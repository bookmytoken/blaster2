rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. The Honeytoken (Deception Layer)
    // Any access to this collection is restricted.
    // In a real app, you would log these attempts via Cloud Audit Logs.
    match /admin_vault/{document=**} {
      allow read, write: if false; 
    }

    // 2. Threat Logs
    // Allow the app to read logs for the dashboard, 
    // and Cloud Functions to write them.
    match /threat_logs/{document=**} {
      allow read: if request.auth != null;
      allow write: if false; // Only Cloud Functions (Admin SDK) can write
    }

    // 3. Encrypted Data (Zero-Trust)
    match /gadget_data/{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
